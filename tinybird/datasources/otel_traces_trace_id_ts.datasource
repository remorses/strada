DESCRIPTION >
    Materialized view target: aggregated trace start/end times by TraceId.
    Populated automatically by the otel_traces_trace_id_ts_mv materialization pipe.

SCHEMA >
    `ProjectId` LowCardinality(String),
    `TraceId` String,
    `Start` AggregateFunction(min, DateTime64(9)),
    `End` AggregateFunction(max, DateTime64(9))

ENGINE "AggregatingMergeTree"
ENGINE_SORTING_KEY "ProjectId, TraceId"
